      "source": [
        "class Human:\n",
        "  def __init__(self, name , age):\n",
        "    self.name =name\n",
        "    self.age = age\n",
        "\n",
        "  def printinfo(self):\n",
        "    print(f\"{self.name} {self.age}歳\")\n",
        "\n",
        "# インスタンス化\n",
        "human = Human(\"侍太郎\" , 20)\n",
        "\n",
        "# 実行\n",
        "human.printinfo()"
      ],
