        "    def __init__(self, name , age):\n",
        "        self.name =name\n",
        "        self.age = age\n",
        "\n",
        "# インスタンス化\n",
        "human = product(\"侍太郎\" , 20)\n",
        "\n",
        "# 実行\n",
        "print(f\"{human.name}  {human.age}才\")\n"
