      "source": [
        "# [関数]税込み価格を計算する\n",
        "# [引数]\n",
        "#   price ： 商品価格\n",
        "#   tax   ： 税率(%)\n",
        "def calculate_tax(price :int , tax :int) -> float:\n",
        "\n",
        "  return price *  ( 1 + tax / 100 )\n",
        "\n",
        "print (f\"{calculate_tax(110,10)}円\")\n"
      ]
    }
