        "#上辺：10cm\n",
        "#下辺：20cm\n",
        "#高さ：5cm\n",
        "\n",
        "#公式：台形の面積 =（上辺＋下辺）× 高さ ÷ 2\n",
        "\n",
        "top_side = 10\n",
        "bottom_side = 20\n",
        "hight = 5\n",
        "trapezoid = ( top_side + bottom_side ) * hight / 2\n",
        "\n",
        "print ( \"台形の面積は\" + str ( trapezoid ) + \" cm² です\"  )\n"
      ]
    }
